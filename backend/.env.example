# ReceiptIQ Backend Environment Variables
# Bu dosyayı .env olarak kopyalayıp gerçek değerlerle doldur. .env asla commitlenmez.

# JWT
SECRET_KEY=change-me-to-a-long-random-string-at-least-64-chars
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# PostgreSQL
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=receiptiq
POSTGRES_PORT=5432

# CORS — virgülle ayır, dev için * kullanabilirsin
BACKEND_CORS_ORIGINS=*

# === Faz 1: OCR ===
# OCR_PROVIDER: tesseract | google_vision
OCR_PROVIDER=tesseract

# Tesseract için (yerel): brew install tesseract tesseract-lang
TESSERACT_LANG=tur+eng

# Google Vision için (bulut): GCP'den service account JSON indir
# GOOGLE_APPLICATION_CREDENTIALS=/Users/buraksayan/keys/receiptiq-vision.json

# === Storage ===
STORAGE_DIR=storage
MAX_UPLOAD_SIZE_MB=10
